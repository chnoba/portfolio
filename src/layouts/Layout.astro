---
import { Font } from 'astro:assets'
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<link rel="preload" href="/cursors/cursor.png" as="image" />
		<link rel="preload" href="/cursors/pointer.png" as="image" />
		<link rel="preload" href="/cursors/click.png" as="image" />

		<Font cssVariable="--font-munro" preload/>
		<Font cssVariable="--font-munro-narrow" preload />
		<Font cssVariable="--font-munro-small" preload/>

		<script is:inline src="/theme-init.js"></script>

		<title>Chnoba</title>
	</head>
	<body class="h-screen flex flex-col overflow-hidden bg-black">
		<slot />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	.nav-link {
		position: relative;
		text-decoration: none;
	}

	.nav-link .corner {
		position: absolute;
		width: 20px;
		height: 20px;
		background-color: var(--color-accent);
		opacity: 0;
		transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		pointer-events: none;
		z-index: 20;
	}

	/* Esquina Superior Izquierda (La que ya teníamos) */
	.tl {
		top: 8px; left: 8px;
		transform: translate(-10px, -10px);
		clip-path: polygon(
			2px 2px, 8px 2px, 8px 4px, 4px 4px, 4px 6px,
			2px 6px, 2px 10px, 0px 10px, 0px 4px, 2px 4px
		);
	}

	/* Esquina Superior Derecha (Mirror X) */
	.tr {
		top: 8px; right: 8px; left: auto;
		transform: translate(10px, -10px);
		clip-path: polygon(
			calc(100% - 2px) 2px, calc(100% - 8px) 2px, calc(100% - 8px) 4px,
			calc(100% - 4px) 4px, calc(100% - 4px) 6px, calc(100% - 2px) 6px,
			calc(100% - 2px) 10px, 100% 10px, 100% 4px, calc(100% - 2px) 4px
		);
	}

	/* Esquina Inferior Izquierda (Mirror Y) */
	.bl {
		bottom: 8px; left: 8px; top: auto;
		transform: translate(-10px, 10px);
		clip-path: polygon(
			2px calc(100% - 2px), 8px calc(100% - 2px), 8px calc(100% - 4px),
			4px calc(100% - 4px), 4px calc(100% - 6px), 2px calc(100% - 6px),
			2px calc(100% - 10px), 0px calc(100% - 10px), 0px calc(100% - 4px), 2px calc(100% - 4px)
		);
	}

	/* Esquina Inferior Derecha (Mirror X & Y) */
	.br {
		bottom: 8px; right: 8px; top: auto; left: auto;
		transform: translate(10px, 10px);
		clip-path: polygon(
			calc(100% - 2px) calc(100% - 2px), calc(100% - 8px) calc(100% - 2px),
			calc(100% - 8px) calc(100% - 4px), calc(100% - 4px) calc(100% - 4px),
			calc(100% - 4px) calc(100% - 6px), calc(100% - 2px) calc(100% - 6px),
			calc(100% - 2px) calc(100% - 10px), 100% 10px, 100% calc(100% - 4px),
			calc(100% - 2px) calc(100% - 4px)
		);
	}

	/* Hover */
	.nav-link:hover .corner,
	.nav-link.active .corner{
		opacity: 1;
		transform: translate(0, 0);
	}

	.nav-link.active {
		color: var(--color-accent);
	}
</style>
