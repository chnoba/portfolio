---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css"
import {MusicPlayer} from '../components/MusicPlayer'
import { STATIONS } from '../data/stations';
import SceneCanvas from "../components/ThreeScene/SceneCanvas";
import CustomCursor from "../components/CustomCursor"

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of <this></this>? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<main>
		<SceneCanvas client:only="react" />
		<div class="flex">
			<MusicPlayer client:only="react" stations={STATIONS}></MusicPlayer>
		</div>
	</main>
	<CustomCursor client:only="react" />
</Layout>
